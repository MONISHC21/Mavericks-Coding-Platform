# OpenAI API Key (Required for AI generation and evaluation)
OPENAI_API_KEY=your_openai_api_key_here

# MongoDB Connection String (Atlas or Local)
MONGO_URL=mongodb+srv://<username>:<password>@cluster.mongodb.net/mavericks?retryWrites=true&w=majority
